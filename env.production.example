# Production Environment Variables Example
# انسخ هذا الملف إلى .env.production واملأ القيم

# Supabase Project URL
VITE_SUPABASE_URL=https://rnwajknqcyjwwujxtaoq.supabase.co

# Supabase Anon/Public Key
# احصل عليه من: https://app.supabase.com/project/rnwajknqcyjwwujxtaoq/settings/api
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ملاحظة: لا تحتاج إلى DATABASE_URL في الإنتاج
# يتم استخدامه فقط في السكريبتات الإدارية

